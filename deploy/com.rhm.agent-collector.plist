<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rhm.agent-collector</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/rhmiyakawa/.claude/agent-collector.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/agent-collector.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/agent-collector.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>AGENT_COCKPIT_MACHINE</key>
        <string>mac</string>
    </dict>
</dict>
</plist>
